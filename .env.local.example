NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_GTM_ID=your_gtm_id
CONTACT_EMAIL_TO=info@len.golf

# Dynamic Pricing API (forms app, public — no auth needed)
# Defaults to https://lengolf-forms.vercel.app/api/pricing if not set
# NEXT_PUBLIC_PRICING_API_URL=https://lengolf-forms.vercel.app/api/pricing

# Google Maps Air Quality API (for AQI widget)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Email (Google Workspace SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=info@len.golf
EMAIL_PASSWORD=your_google_app_password
EMAIL_FROM=info@len.golf
